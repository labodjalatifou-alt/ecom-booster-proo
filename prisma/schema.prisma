generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model Store {
  id              String   @id @default(cuid())
  name            String   // e.g. "Boutique Abidjan"
  country         String   @default("Côte d'Ivoire")
  currency        String   // "FCFA", "GNF", etc.
  shopifyUrl      String   @map("shopifyUrl")
  shopifyToken    String   @map("shopifyToken")
  createdAt       DateTime @default(now()) @map("createdAt")
  updatedAt       DateTime @default(now()) @updatedAt @map("updatedAt")
  
  // Relations
  orders          Order[]
  products        Product[]
  users           UserStore[]

  @@schema("public")
}

enum Role {
  ADMIN
  CLOSER
  LIVREUR
  @@schema("public")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          Role     @default(CLOSER)
  
  commissionPerConfirm Int @default(0)
  commissionPerDeliver Int @default(0)
  earnings             Int @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  
  // Relations
  stores        UserStore[]
  assignedOrders Order[] @relation("CloserOrders")
  deliveryOrders Order[] @relation("LivreurOrders")

  @@schema("public")
}

model UserStore {
  userId   String
  storeId  String
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store    Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@schema("public")
}

model Order {
  id              String   @id @default(cuid())
  shopifyOrderId  String   @unique @map("shopify_id")
  storeId         String?  @map("store_id")
  store           Store?   @relation(fields: [storeId], references: [id])
  
  customerName    String   @map("customer")
  customerPhone   String   @map("phone")
  product         String
  price           String?  @map("price")
  currency        String   @default("FCFA")
  status          String   @default("A Confirmer")
  city            String?
  cash_received   Boolean  @default(false)
  cash_collected  Int?
  delivery_fee    Int?     @default(0)
  delivery_fee_included Boolean @default(false)
  programmed_date DateTime?
  
  closer_id       String?
  closer          User?    @relation("CloserOrders", fields: [closer_id], references: [id])
  
  livreur_id      String?
  livreur         User?    @relation("LivreurOrders", fields: [livreur_id], references: [id])
  
  closer_paid     Int?     @default(0)
  
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  @@map("orders")
  @@schema("public")
}

enum OrderStatus {
  PENDING      // En attente
  CONFIRMED    // Confirmé par le closer
  SHIPPED      // En cours de livraison
  DELIVERED    // Livré
  RETURNED     // Retour
  FAILED       // Échec
  @@schema("public")
}

model Product {
  id            String   @id @default(uuid())
  shopifyId     String   @unique @map("shopify_id")
  storeId       String?  @map("store_id")
  store         Store?   @relation(fields: [storeId], references: [id])
  
  title         String
  price         String
  comparePrice  String?  @map("compare_price")
  status        String   // active, draft, etc.
  stock         Int      @default(0)
  imageUrl      String?  @map("image_url")
  images        Json?    @map("images")
  currency      String   @default("FCFA")
  description   String?  @map("description")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("products")
  @@schema("public")
}

model ProductAnalysis {
  id                   String   @id @default(cuid())
  product_name         String
  score                Int
  price_recommendation String
  cost_price           String?
  customer_avatar      Json
  shopify_page_content Json
  facebook_ad_content  Json
  launch_strategy      Json?
  voiceover_script     Json
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("analyses")
  @@schema("public")
}
