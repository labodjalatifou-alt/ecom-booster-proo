generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Store {
  id              String   @id @default(cuid())
  name            String   // e.g. "Boutique Abidjan"
  currency        String   // "FCFA", "GNF", etc.
  shopifyUrl      String   // e.g. "mystore.myshopify.com"
  shopifyToken    String   // shpat_...
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  orders          Order[]
  users           UserStore[]
}

enum Role {
  ADMIN
  CLOSER
  LIVREUR
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          Role     @default(CLOSER)
  
  commissionPerConfirm Int @default(0)
  commissionPerDeliver Int @default(0)
  earnings             Int @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  stores        UserStore[]
  assignedOrders Order[] @relation("CloserOrders")
  deliveryOrders Order[] @relation("LivreurOrders")
}

model UserStore {
  userId   String
  storeId  String
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store    Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}

model Order {
  id              String   @id @default(cuid())
  shopifyOrderId  String   @unique @map("shopify_id")
  storeId         String?  @map("store_id")
  store           Store?   @relation(fields: [storeId], references: [id])
  
  customerName    String   @map("customer")
  customerPhone   String   @map("phone")
  product         String
  price           String?  @map("price")
  currency        String   @default("FCFA")
  status          String   @default("A Confirmer")
  city            String?
  cashReceived    Boolean  @default(false) @map("cash_received")
  cashCollected   Int?     @map("cash_collected")
  programmedDate  DateTime? @map("programmed_date")
  
  closerId        String?  @map("closer_id")
  closer          User?    @relation("CloserOrders", fields: [closerId], references: [id])
  
  livreurId       String?  @map("livreur_id")
  livreur         User?    @relation("LivreurOrders", fields: [livreurId], references: [id])
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("orders")
}

enum OrderStatus {
  PENDING      // En attente
  CONFIRMED    // Confirmé par le closer
  SHIPPED      // En cours de livraison
  DELIVERED    // Livré
  RETURNED     // Retour
  FAILED       // Échec
}

model Product {
  id            String   @id @default(cuid())
  shopifyId     String   @unique @map("shopify_id")
  title         String
  price         String
  comparePrice  String?  @map("compare_price")
  status        String   // active, draft, etc.
  stock         Int      @default(0)
  imageUrl      String?  @map("image_url")
  currency      String   @default("FCFA")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("products")
}

model ProductAnalysis {
  id                   String   @id @default(cuid())
  product_name         String
  score                Int
  price_recommendation String
  customer_avatar      Json
  shopify_page_content Json
  facebook_ad_content  Json
  voiceover_script     String
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("analyses")
}
